<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Sweet Bakery</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">
    <h1>Sweet Bakery</h1>
    <p class="subtitle">Fresh, Sweet & Made with Love</p>

    <form action="/add" method="POST">
        <input type="text" name="nama" placeholder="Masukkan Nama Kamu" required>

        <div class="products">
            <% products.forEach(product => { %>
                <label class="card">
                    <img src="/<%= product.gambar %>" alt="<%= product.nama %>">
                    <h3><%= product.nama %></h3>
                    <p class="price">Rp<%= product.harga.toLocaleString("id-ID") %></p>

                    <input type="radio" name="produk" value="<%= product.nama %>" required>
                    <span>Pilih</span>
                </label>
            <% }) %>
        </div>

        <input type="number" name="jumlah" min="1" value="1" required>

        <br>

        <button type="submit">Pesan Sekarang</button>
    </form>

    <a href="/orders" class="btn-back">Lihat Pesanan</a>
</div>

</body>
</html>