<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Edit Pesanan</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">
    <h1>Edit Pesanan</h1>

    <form action="/update/<%= order.id %>" method="POST">
        <input type="text" name="nama" value="<%= order.nama %>" required>

        <select name="produk" required>
            <% products.forEach(product => { %>
                <option value="<%= product.nama %>" <%= order.produk === product.nama ? "selected" : "" %>>
                    <%= product.nama %>
                </option>
            <% }) %>
        </select>

        <input type="number" name="jumlah" min="1" value="<%= order.jumlah %>" required>

        <br>

        <button type="submit">Update</button>
    </form>

    <a href="/orders" class="btn-back">Kembali</a>
</div>

</body>
</html>